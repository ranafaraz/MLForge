# MLForge runs fully offline by default (numpy only). Everything below is
# OPTIONAL. Copy to `.env` to change the default experiment.

# --- Selection protocol (the independent variable) ---
# nested   (default, honest: nested cross-validation, no leakage, no selection bias) |
# pipeline (preprocessing refit inside each fold, but flat best-of-grid selection) |
# leaky    (preprocessing fit on ALL data + flat best-of-grid: the textbook mistake)
MLFORGE_PROTOCOL=nested

# --- Dataset regime ---
# highdim (default, p>>informative: feature selection leakage bites hard) |
# lowdim  (control: few all-informative features, nothing to overfit) |
# null    (random labels: any reported signal is an artifact)
MLFORGE_DATASET=highdim

# --- Tunables (deterministic; tweak for experiments) ---
# MLFORGE_SEED=0
# MLFORGE_FOLDS=5            # cross-validation folds (outer folds for nested)
# MLFORGE_INNER_FOLDS=4      # inner folds (nested protocol only)

# --- Optional cross-check backend ---
# Install with: pip install "mlforge[sklearn]"
# Re-runs the same three protocols with scikit-learn to confirm the numbers agree.
# MLFORGE_BACKEND=numpy      # numpy (default) | sklearn
